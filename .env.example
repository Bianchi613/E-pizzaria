# Copie para .env e preencha com seus valores reais.
# (o .env é ignorado pelo git — nunca comite segredos)

# =====================================
# BANCO DE DADOS
# As tabelas (clientes, pedidos) ficam no banco "evolution".
# Aplique o esquema: psql -h localhost -U postgres -d evolution -f schema.sql
# =====================================
DB_HOST=localhost
DB_NAME=evolution
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# =====================================
# PROVEDOR DE IA
# Opções: ollama | api  (api = OpenAI, xAI ou compatível /v1/chat/completions)
# =====================================
LLM_PROVIDER=api

# --- API Cloud (xAI / OpenAI / OpenRouter...) ---
# usado quando LLM_PROVIDER=api
CHAT_API_KEY=sua_chave_aqui
CHAT_API_BASE_URL=https://api.x.ai/v1
CHAT_API_MODEL=grok-4-fast
# Opcionais: CHAT_API_TIMEOUT, CHAT_API_MAX_TOKENS, CHAT_API_TEMPERATURE, CHAT_API_TOP_P

# --- Ollama (local) ---
# usado quando LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_HOST=http://localhost:11434

# =====================================
# EVOLUTION API
# =====================================
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=pizzaria2
EVOLUTION_API_KEY=sua_apikey_evolution

# Ignorar mensagens enviadas pelo próprio número (evita loop em produção).
# Mantenha false enquanto testa com o seu próprio WhatsApp.
IGNORE_FROM_ME=true

# =====================================
# FLASK
# =====================================
FLASK_PORT=5000
